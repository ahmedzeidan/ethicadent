# Development image for the Ethicadent Next.js site (hot reload)
FROM node:20-alpine

WORKDIR /app

# Install dependencies based on the lockfile for reproducible installs.
COPY package.json package-lock.json ./
RUN npm ci

# Source is bind-mounted at runtime via docker-compose; copy as a fallback
# so the image is also usable on its own.
COPY . .

EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0"]
